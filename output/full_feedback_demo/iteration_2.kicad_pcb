      (plotvalue false)
      (plotinvisibletext false)
      (sketchpadsonfab false)
      (subtractmaskfromsilk false)
      (outputformat 0)
      (mirror false)
      (drillshape 0)
      (scaleselection 1)
      (outputdirectory "")
