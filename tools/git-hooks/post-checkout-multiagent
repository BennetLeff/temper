#!/bin/bash
# Multi-Agent Post-Checkout Hook
#
# This hook notifies users when they checkout a branch claimed by another agent.
# It's informational only - it doesn't block the checkout.
#
# Installation:
#   Copy to .git/hooks/post-checkout
#   Or run: tools/git-hooks/install-multiagent.sh

set -e

# Post-checkout receives: previous HEAD, new HEAD, branch flag
# We only care about branch checkouts (flag=1)
BRANCH_CHECKOUT="$3"
if [[ "$BRANCH_CHECKOUT" != "1" ]]; then
    exit 0
fi

# Find repo root
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)

# Source multi-agent utilities
MULTIAGENT_SCRIPT="$REPO_ROOT/tools/bd-multiagent.sh"
if [[ ! -f "$MULTIAGENT_SCRIPT" ]]; then
    exit 0
fi

# shellcheck source=/dev/null
source "$MULTIAGENT_SCRIPT" 2>/dev/null

# Run the notification check
_bd_postcheckout_notify

exit 0
