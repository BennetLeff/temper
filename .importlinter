# import-linter boundary configuration for Temper
# docs/plans/2026-06-22-014-feat-import-linter-boundary-enforcement-plan.md
#
# Contracts:
#   - core-isolated-from-router-v6: independence (R2)
#   - core-public-interface-only: forbid internal submodule imports (R3)
#   - router-v6-public-interface-only: forbid internal submodule imports (R3)

[importlinter]
root_packages =
    temper_placer

# R2: core/ must not import from router_v6/ (router_v6 may use core types).
[importlinter:contract:core-isolated-from-router-v6]
name = core-isolated-from-router-v6
type = forbidden
source_modules =
    temper_placer.core
forbidden_modules =
    temper_placer.router_v6

# R3: External packages may only import from core/ public interface (__init__.py).
# Only explicitly listed submodules are forbidden; the package root (__init__.py) is allowed.
[importlinter:contract:core-public-interface-only]
name = core-public-interface-only
type = forbidden
source_modules =
    temper_placer.ablation
    temper_placer.adapters
    temper_placer.cli
    temper_placer.constraints
    temper_placer.deterministic
    temper_placer.experiments
    temper_placer.explainability
    temper_placer.fixtures
    temper_placer.geometry
    temper_placer.heuristics
    temper_placer.io
    temper_placer.losses
    temper_placer.manufacturing
    temper_placer.metrics
    temper_placer.ml
    temper_placer.optimizer
    temper_placer.pcl
    temper_placer.pipeline
    temper_placer.placement
    temper_placer.placer
    temper_placer.regression
    temper_placer.router_v6
    temper_placer.scale
    temper_placer.topological
    temper_placer.validation
    temper_placer.visualization
forbidden_modules =
    temper_placer.core.graph
    temper_placer.core.placement_drc
    temper_placer.core.power_topology
    temper_placer.core.routing_validator
as_packages = False
ignore_imports =
    temper_placer.core.* -> temper_placer.core.*

# R3: External packages may only import from router_v6/ public interface (__init__.py).
[importlinter:contract:router-v6-public-interface-only]
name = router-v6-public-interface-only
type = forbidden
source_modules =
    temper_placer.ablation
    temper_placer.adapters
    temper_placer.cli
    temper_placer.constraints
    temper_placer.core
    temper_placer.deterministic
    temper_placer.experiments
    temper_placer.explainability
    temper_placer.fixtures
    temper_placer.geometry
    temper_placer.heuristics
    temper_placer.io
    temper_placer.losses
    temper_placer.manufacturing
    temper_placer.metrics
    temper_placer.ml
    temper_placer.optimizer
    temper_placer.pcl
    temper_placer.pipeline
    temper_placer.placement
    temper_placer.placer
    temper_placer.regression
    temper_placer.routing
    temper_placer.scale
    temper_placer.topological
    temper_placer.validation
    temper_placer.visualization
forbidden_modules =
    temper_placer.router_v6.acid_trap_detection
    temper_placer.router_v6.adapter
    temper_placer.router_v6.annular_ring_check
    temper_placer.router_v6.apply_suggestions
