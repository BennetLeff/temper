
{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "provider": {
    "anthropic": {
      "models": {
        "claude-sonnet-4-5": {},
        "claude-haiku-4-5": {},
        "claude-opus-4-5": {}
      }
    },
    "google": {
      "models": {
        "gemini-3-pro": {
          "options": {
            "maxOutputTokens": 16000
          }
        }
      }
    },
    "openrouter": {
      "models": {
        "openrouter/deepseek/deepseek-v3.2-speciale": {
          "options": {
            "provider": {
              "order": ["baseten"],
              "allow_fallbacks": false
            }
          }
        },
        "openrouter/minimax/minimax-m2": {}
      }
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-5",
      "description": "Planning agent using Claude Opus 4.5",
      "temperature": 0.1,
      "tools": { "write": false, "edit": false, "bash": false }
    },
    "build": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-5",
      "description": "Build agent using Claude Sonnet 4.5",
      "temperature": 0.3,
      "tools": { "write": true, "edit": true, "bash": true }
    },
    "fast-build": {
      "mode": "subagent",
      "model": "openrouter/minimax/minimax-m2",
      "description": "Fast build agent using MiniMax M2",
      "temperature": 0.3,
      "tools": { "write": true, "edit": true, "bash": true }
    }
  }
}
