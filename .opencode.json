{
  "agents": {
    "plan": {
      "name": "Plan",
      "description": "High-level planning and coordination agent using Claude Opus 4.5",
      "model": "claude-opus-4-5",
      "provider": "anthropic",
      "temperature": 0.7,
      "maxTokens": 131072,
      "capabilities": [
        "planning",
        "architecture",
        "coordination",
        "code-review"
      ]
    },
    "build": {
      "name": "Build",
      "description": "Implementation and execution agent using Claude Sonnet 4.5 via GitHub Copilot",
      "model": "github-copilot/claude-sonnet-4.5",
      "provider": "github-copilot",
      "temperature": 0.5,
      "maxTokens": 200000,
      "capabilities": [
        "implementation",
        "testing",
        "debugging",
        "documentation"
      ]
    }
  },
  "workflows": {
    "plan-and-implement": {
      "description": "Plan creates plan, build implements",
      "steps": [
        {
          "agent": "plan",
          "action": "analyze_and_plan",
          "output": "implementation_plan"
        },
        {
          "agent": "build",
          "action": "implement",
          "input": "implementation_plan"
        }
      ]
    },
    "review-workflow": {
      "description": "Build implements, plan reviews",
      "steps": [
        {
          "agent": "build",
          "action": "implement"
        },
        {
          "agent": "plan",
          "action": "review_and_approve"
        }
      ]
    }
  },
  "settings": {
    "defaultAgent": "build",
    "parallelExecution": true,
    "maxRetries": 3,
    "timeout": 300000
  }
}
