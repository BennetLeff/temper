(kicad_pcb (version 20221018) (generator temper_placer)

  (general
    (thickness 1.6)
  )

  (paper "A3")
  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal)
    (2 "In2.Cu" signal)
    (31 "B.Cu" signal)
